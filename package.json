{
  "name": "praiseprojector-electron",
  "version": "2.0.28",
  "private": true,
  "description": "Cross-platform praise presentation software (source-available, non-commercial, not open source)",
  "main": "dist/electron/main.js",
  "workspaces": [
    "client"
  ],
  "scripts": {
    "start": "npm run dev",
    "dev": "npx vite",
    "dev:web": "npx vite --mode web",
    "dev:electron": "electron .",
    "build": "npm run build --workspace=client && npx vite build",
    "build:web": "npx vite build --mode web && rimraf dist/webapp/app",
    "generate-icons": "node scripts/generate-icons.js",
    "deploy": "npm run clean && npm run build --workspace=client && npm run dist:linux && npm run dist:mac && npm run generate-icons && npm run dist:win && npm run build:web",
    "dist": "npm run build && electron-builder --publish never",
    "dist:win": "node -e \"const v=require('electron/package.json').version; require('child_process').execSync('npm run generate-icons && npm run build && npx electron-builder --win --publish never -c.electronVersion=' + v, {stdio: 'inherit'})\"",
    "dist:mac": "node -e \"process.platform === 'darwin' ? require('child_process').execSync('npm run generate-icons && npm run build && npx electron-builder --mac --publish never', {stdio: 'inherit'}) : require('child_process').execSync('node scripts/build-container-target.js mac', {stdio: 'inherit'})\"",
    "dist:linux": "node -e \"process.platform === 'linux' ? require('child_process').execSync('npm run generate-icons && npm run build && npx electron-builder --linux --publish never', {stdio: 'inherit'}) : require('child_process').execSync('node scripts/build-container-target.js linux', {stdio: 'inherit'})\"",
    "dist:pkg": "npm run build && node scripts/dist-pkg.js",
    "clean": "rimraf dist public/assets/pp.icns public/assets/pp.ico public/assets/pp.png",
    "postinstall": "node scripts/run-electron-rebuild.js",
    "rebuild": "node scripts/run-electron-rebuild.js",
    "install:ble-peripheral": "npm install @abandonware/bleno --save-exact && npm run rebuild",
    "check-port": "netstat -ano | findstr :5173 || echo Port 5173 is free",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"electron/**/*.ts\" \"client/**/*.ts\" \"common/**/*.ts\" \"chordpro/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"electron/**/*.ts\" \"client/**/*.ts\" \"common/**/*.ts\" \"chordpro/**/*.ts\"",
    "check:ts": "tsc -p tsconfig.json --noEmit && tsc -p client/tsconfig.json --noEmit"
  },
  "license": "PolyForm-Noncommercial-1.0.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/cors": "^2.8.19",
    "@types/diff": "^5.0.9",
    "@types/express": "^5.0.5",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/uuid": "^10.0.0",
    "@types/web-bluetooth": "^0.0.21",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "@vitejs/plugin-react": "^4.2.1",
    "baseline-browser-mapping": "^2.9.19",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "glob": "^10.5.0",
    "png2icons": "^2.0.1",
    "prettier": "^3.6.2",
    "rimraf": "^5.0.10",
    "sharp": "^0.34.5",
    "typescript": "^5.0.0",
    "vite": "^6.4.1",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-tsconfig-paths": "^4.3.2"
  },
  "dependencies": {
    "abcjs": "^6.4.5",
    "axios": "^1.13.2",
    "bootstrap": "^5.3.0",
    "cors": "^2.8.5",
    "diff": "^5.2.0",
    "electron-updater": "^6.7.3",
    "express": "^5.1.0",
    "fflate": "^0.8.2",
    "font-awesome": "^4.7.0",
    "fp-ts": "^2.16.11",
    "io-ts": "^2.2.22",
    "localforage": "^1.10.0",
    "mammoth": "^1.11.0",
    "midi.js": "^0.3.1",
    "pdfjs-dist": "^5.4.394",
    "qrcode.react": "^4.2.0",
    "react": "^18.0.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.0.0",
    "react-resizable-panels": "^3.0.6",
    "tiny-emitter": "^2.1.0",
    "typesense": "^1.8.2",
    "uuid": "^13.0.0",
    "yalps": "^0.5.7"
  },
  "build": {
    "appId": "com.praiseprojector.electron",
    "productName": "PraiseProjector",
    "icon": "dist/build/icon",
    "afterPack": "./scripts/after-pack-linux-no-sandbox.cjs",
    "directories": {
      "output": "dist/executables",
      "buildResources": "dist/build"
    },
    "files": [
      "dist/webapp/**/*",
      "dist/electron/**/*",
      "proxy-config*.json",
      "node_modules/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": {
      "provider": "generic",
      "url": "https://praiseprojector.hu/releases/electron",
      "useMultipleRangeRequest": false
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "dist/build/icon.icns"
    },
    "win": {
      "icon": "dist/build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "installerIcon": "dist/build/icon.ico",
      "uninstallerIcon": "dist/build/icon.ico",
      "installerHeaderIcon": "dist/build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PraiseProjector",
      "differentialPackage": true
    },
    "linux": {
      "icon": "dist/build/icon.png",
      "target": "AppImage",
      "executableArgs": [
        "--no-sandbox",
        "--disable-gpu-sandbox"
      ]
    }
  }
}
