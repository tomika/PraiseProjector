{
  "name": "pp-client",
  "version": "2.0.1",
  "private": true,
  "description": "PraiseProjector browser client",
  "scripts": {
    "build": "npm run build:release",
    "build:debug": "node ./build.js --debug",
    "build:release": "node ./build.js --release",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yml,yaml}\""
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.25.10",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "color-calendar": "^1.0.7",
    "core-js": "^3.19.1",
    "fp-ts": "^2.16.11",
    "io-ts": "^2.2.22",
    "localforage": "^1.10.0",
    "tiny-emitter": "^2.1.0",
    "uuid": "^13.0.0",
    "yalps": "^0.5.7"
  }
}
